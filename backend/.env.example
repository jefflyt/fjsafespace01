# Backend environment variables — copy to .env and fill in values
# Phase 1/2 — all variables below are required from day one

# PostgreSQL connection string for the main app DB role
# This role has full read/write on Workflow B tables,
# but SELECT-only on Rulebook tables (RulebookEntry, CitationUnit, ReferenceSource)
DATABASE_URL=postgresql://dev:dev@localhost:5432/fjsafespace

# Full-privilege DB role for Workflow A admin console
# Never used by any dashboard service — admin console only
ADMIN_DATABASE_URL=postgresql://admin:admin@localhost:5432/fjsafespace

# Jay Choy's email — enforced by QA-G8 for certification report approval
APPROVER_EMAIL=jaychoy@example.com

# Resend API key for email notifications
RESEND_API_KEY=re_replace_me

# ── Phase 3 only (Clerk) ──────────────────────────────────────────────────────
# CLERK_SECRET_KEY=sk_replace_me
